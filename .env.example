# ── Required ──

# Your public-facing URL (no trailing slash)
BETTER_AUTH_URL=https://spotitrack.example.com
BETTER_AUTH_SECRET=generate-a-long-random-string-here
BETTER_AUTH_TRUSTED_ORIGINS=https://spotitrack.example.com

# Postgres
POSTGRES_USER=spotitrack
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=spotitrack
DATABASE_URL=postgres://spotitrack:change-me-to-a-strong-password@db:5432/spotitrack

# Spotify OAuth — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=https://spotitrack.example.com/api/auth/callback/spotify

# Also exposed to the client build
VITE_BETTER_AUTH_URL=https://spotitrack.example.com
